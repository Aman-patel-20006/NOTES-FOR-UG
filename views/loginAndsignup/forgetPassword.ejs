<% layout("layoutAll/layout.ejs") -%>
<div id="loginMiandiv">
  <div class="card">
    <div class="brand">
      <h1>ENTER YOUR EMAIL FOR FORGET PASSWORD</h1>
    </div>
    <!-- ✅ FORM START -->
    <form action="/forgetPassword" method="post">
      <div class="field">
        <label>Email</label>
        <div class="input-wrap">
          <input type="email" name="email" placeholder="Enter email" required>
        </div>
      </div>
      <!-- ✅ BUTTON INSIDE FORM -->
      <button class="btn-login" id="forgetpass-btn" type="submit">SUBMIT</button>
    </form>
  </div>
  </div>