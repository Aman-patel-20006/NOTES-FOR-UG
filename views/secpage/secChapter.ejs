<% layout("./layoutAll/layout.ejs") -%>
  <div id="chapterContainer">
    <% if(!data){ data=[]; } %>
      <% for (let item of data) { %>
        <div class="chapter">
          <!-- PDF Image -->
          <div class="chapter-image">
            <% let link=item.src; let id=item.src.slice(item.src.indexOf("/d/")+3,item.src.indexOf("/view")) %>
              <img src="https://drive.google.com/thumbnail?id=<%=id %>" alt="PDF Preview" id="pdfImage"
                onerror="this.onerror=null; this.src='/image/pdfImage.png';">
          </div>
          <div class="chapter-info">
            <h4 class="chapter-title"> <span>Title:</span>
              <%= item.title %>
            </h4>
            <div class="chapter-buttons">
              <form action="/editchapter/<%= semester %>" method="get" class="chapter-form">
                <input type="hidden" name="title" value="<%= item.title %>">
     <% if(currUser && currUser.admin) { %>
                  <button type="submit" class="btn edit-button" disabled>EDIT</button>
               <% } else if( item.uploadedBy && item.uploadedBy._id && currUser && currUser._id.toString()===item.uploadedBy._id.toString() ) { %>
                  <button type="submit" class="btn edit-button" disabled>EDIT</button>
 <% } %>
              </form>
              <form action="/viewsChapterpdf" method="get" class="chapter-form">
                <input type="hidden" name="src" value="<%= item.src %>">
                <button type="submit" class="btn view-button">VIEW</button>
              </form>
              <form action="/deletechapter?_method=DELETE" method="post" class="chapter-form">
                <input type="hidden" name="subject" value="<%=name%>">
                <input type="hidden" name="fileID" value="<%=id%>">
                <input type="hidden" name="Semester" value="<%=semester %>">
                <input type="hidden" name="objectID" value="<%=item._id%>">
     <% if(currUser && currUser.admin) { %>
                  <button type="submit" class="btn delete-button"
                    onclick="return confirm('Are you sure you want to delete this?'); ">DELETE</button>
                   <% } else if( item.uploadedBy && item.uploadedBy._id && currUser && currUser._id.toString()===item.uploadedBy._id.toString() ) { %>
                  <button type="submit" class="btn delete-button"
                    onclick="return confirm('Are you sure you want to delete this?'); ">DELETE</button>
                    <% } %>
              </form>
            </div>
          </div>
        </div>
        <% } %>
  </div>
  <script>window.addEventListener("pageshow", (event) => {
  if (event.persisted || performance.getEntriesByType("navigation")[0]?.type === "back_forward") {
    window.location.reload();
  }
});</script>